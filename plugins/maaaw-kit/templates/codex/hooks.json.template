{
  "_comment": "Generated by MaaawKit. Codex project-local hooks require project trust and non-managed command hooks require /hooks review/trust before they run. Do not trust hooks from repositories you do not control.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": [".codex/hooks/session-context.py"],
            "timeout": 20,
            "statusMessage": "Loading project context"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": [".codex/hooks/guard.py"],
            "timeout": 15,
            "statusMessage": "Checking safety policy"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": [".codex/hooks/post-edit-check.py"],
            "timeout": 120,
            "statusMessage": "Running edit checks"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": [".codex/hooks/stop-verify.py"],
            "timeout": 630,
            "statusMessage": "Running verification oracle"
          }
        ]
      }
    ]
  }
}
