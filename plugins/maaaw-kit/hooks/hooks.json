{
  "description": "maaaw-kit hooks: destructive-command guard, per-edit format+lint feedback, oracle-enforced verification loop, session context injection (zero-dep Node shims; full engine behavior when the maaawkit package is installed)",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell|Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "node", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/guard.mjs"], "timeout": 15, "statusMessage": "Checking safety policy" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "node", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/post-edit.mjs"], "timeout": 120, "statusMessage": "Running edit checks" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "node", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/stop-verify.mjs"], "timeout": 630, "statusMessage": "Running verification oracle" }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "node", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/session-context.mjs"], "timeout": 20, "statusMessage": "Loading project context" }
        ]
      }
    ]
  }
}
