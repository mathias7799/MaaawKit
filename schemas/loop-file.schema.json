{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "trusted": {
      "type": "boolean",
      "const": true
    },
    "created_by": {
      "type": "string"
    },
    "oracle": {
      "type": "string",
      "minLength": 1
    },
    "max_iterations": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "timeout_seconds": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "max_output": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "goal": {
      "type": "string"
    },
    "iteration": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "last_failure_sig": {
      "type": "string"
    },
    "failure_streak": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    }
  },
  "required": [
    "trusted",
    "oracle",
    "max_iterations"
  ]
}
