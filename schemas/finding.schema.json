{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "severity": {
      "type": "string",
      "enum": [
        "critical",
        "high",
        "medium",
        "low",
        "info"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "file": {
      "type": "string"
    },
    "line": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "evidence": {
      "type": "string",
      "minLength": 1
    },
    "recommendation": {
      "type": "string"
    },
    "confidence": {
      "default": "medium",
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "lane": {
      "type": "string"
    }
  },
  "required": [
    "severity",
    "title",
    "evidence"
  ]
}
