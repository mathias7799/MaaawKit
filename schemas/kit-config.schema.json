{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "stacks": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "dotnet",
          "node",
          "python",
          "powershell"
        ]
      }
    },
    "oracle": {
      "type": "string"
    },
    "guardLevel": {
      "default": "standard",
      "type": "string",
      "enum": [
        "relaxed",
        "standard",
        "strict"
      ]
    },
    "guardCustomRules": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "pattern": {
            "type": "string",
            "minLength": 1
          },
          "flags": {
            "type": "string"
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "enum": [
              "deny",
              "ask"
            ]
          }
        },
        "required": [
          "pattern",
          "message",
          "action"
        ]
      }
    },
    "secondAgents": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "issueTracker": {
      "type": "string"
    },
    "docsDir": {
      "default": "docs",
      "type": "string"
    },
    "dials": {
      "default": {},
      "type": "object",
      "properties": {
        "auditDepth": {
          "default": "standard",
          "type": "string",
          "enum": [
            "quick",
            "standard",
            "deep"
          ]
        },
        "paranoia": {
          "default": "standard",
          "type": "string",
          "enum": [
            "low",
            "standard",
            "high"
          ]
        }
      }
    },
    "memory": {
      "default": {},
      "type": "object",
      "properties": {
        "digestTokenBudget": {
          "default": 1500,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "decayDays": {
          "default": 45,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "promoteHitThreshold": {
          "default": 3,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      }
    },
    "mcp": {
      "default": {},
      "type": "object",
      "properties": {
        "writeModeClients": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
