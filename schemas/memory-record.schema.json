{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^mem_[a-z0-9]{4,12}$"
    },
    "type": {
      "type": "string",
      "enum": [
        "lesson",
        "decision",
        "repo-fact",
        "preference",
        "failure-pattern"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "paths": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "default": "medium",
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "status": {
      "default": "active",
      "type": "string",
      "enum": [
        "active",
        "stale",
        "promoted",
        "archived"
      ]
    },
    "created": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "lastConfirmed": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "hits": {
      "default": 0,
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "source": {
      "default": "session",
      "type": "string"
    }
  },
  "required": [
    "id",
    "type",
    "title",
    "created",
    "lastConfirmed"
  ]
}
